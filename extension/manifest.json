{
  "manifest_version": 3,
  "name": "Send to Grain",
  "version": "0.0.1",
  "description": "Capture links, images, and pages into Grain.",
  "icons": {
    "16": "dist/icons/grain-16.png",
    "32": "dist/icons/grain-32.png",
    "48": "dist/icons/grain-48.png",
    "128": "dist/icons/grain-128.png"
  },
  "action": {
    "default_title": "Send to Grain",
    "default_icon": {
      "16": "dist/icons/grain-16.png",
      "32": "dist/icons/grain-32.png"
    },
    "default_popup": "dist/popup.html"
  },
  "background": {
    "service_worker": "dist/background/index.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "<all_urls>"
  ]
}
